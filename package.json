{
  "name": "hattrictos-stats",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter hattrictos-stats-api dev",
    "dev:web": "bun run --filter hattrictos-stats-web dev",
    "test": "bun run --filter '*' test",
    "test:api": "bun run --filter hattrictos-stats-api test",
    "typecheck": "./node_modules/.bin/tsc --noEmit -p apps/backend/tsconfig.json && ./node_modules/.bin/tsc --noEmit -p apps/frontend/tsconfig.json",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "build": "bun run --filter '*' build",
    "db:generate": "bun run --filter hattrictos-stats-api db:generate",
    "db:migrate": "bun run --filter hattrictos-stats-api db:migrate",
    "clean": "bun run scripts/clean-template.ts",
    "generate": "bun run scripts/generate-feature.ts",
    "arch-check": "bun run scripts/arch-check.ts",
    "postinstall": "lefthook install || true"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "hattrictos-stats-api": "workspace:*",
    "lefthook": "^2.1.1",
    "typescript": "^5.8.3"
  }
}
