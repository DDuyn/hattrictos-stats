# Backend
PORT=3000
JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=7d            # Token duration. Formats: 7d, 24h, 3600s. Default: 7d

# CORS — set to your frontend domain in production to restrict cross-origin access
# CORS_ORIGIN=https://my-app.pages.dev   # Default: * (all origins)

# Node environment — controls log format and LOG_LEVEL default
# NODE_ENV=production          # Set to 'production' in Render / CI

# Database (Turso) — in dev, uses local SQLite file; in prod, connect to Turso
TURSO_DATABASE_URL=file:./local.db
# TURSO_AUTH_TOKEN=        # Only needed for remote Turso database

# Rate limiting (optional — defaults shown)
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
# RATE_LIMIT_MAX=10             # Max attempts per window per IP

# Logging
# LOG_LEVEL=warn                # Minimum level sent to Betterstack: info | warn | error
#                               # Default: 'info' in dev, 'warn' in production

# Observability: Betterstack (Logtail) — optional
# Without a token, logs only go to stdout (local console). No external traffic.
# To set up: https://betterstack.com → Telemetry → Sources → Connect source (type: HTTP)
# BETTERSTACK_SOURCE_TOKEN=     # Source token from Betterstack dashboard
# BETTERSTACK_HOST=in.logs.betterstack.com   # Default ingestion host

# ─────────────────────────────────────────────────────────────────────────────
# CHPP — Hattrick API (Certified Hattrick Product Program)
# Register your app at https://chpp.hattrick.org to get consumer credentials.
# NEVER commit these values. Add them to your deployment environment (Render, etc.)
# See docs/chpp-oauth.md for the full OAuth 1.0a flow.
# ─────────────────────────────────────────────────────────────────────────────

# App credentials — obtained when registering the app in CHPP (fixed, never change)
# CHPP_CONSUMER_KEY=
# CHPP_CONSUMER_SECRET=

# Admin access token — obtained after the admin completes the OAuth 1.0a flow
# These are updated if the token is revoked and the admin re-authorizes the app.
# CHPP_ACCESS_TOKEN=
# CHPP_ACCESS_TOKEN_SECRET=

# App URL — used as the OAuth callback base URL
# APP_URL=http://localhost:3000   # In production: https://your-app.com

